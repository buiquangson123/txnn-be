PORT=3000
# Danh sách domain FE được phép gọi API, cách nhau bởi dấu phẩy. Để trống = cho phép tất cả (chỉ dùng khi dev).
ALLOWED_ORIGINS=https://your-admin-web.vercel.app

# Mã DN icheck 7 số (dùng làm tiền tố khi tự sinh Mã doanh nghiệp cho DN không có mã GS1)
ICHECK_PREFIX=9938899

# Auth
JWT_SECRET=doi-chuoi-nay-thanh-chuoi-bi-mat-dai-va-kho-doan
JWT_EXPIRES_IN=7d

# Web public hiển thị truy xuất - dùng để nhúng vào nội dung mã QR
PUBLIC_TRACE_BASE_URL=https://trace.example.com/san-pham

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/txng?retryWrites=true&w=majority

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=txng-images
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL_BASE=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
